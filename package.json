{
  "name": "gesturo",
  "version": "0.1.0",
  "description": "Entraînement au dessin de poses",
  "author": "Gesturo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.gesturo.app",
    "productName": "Gesturo",
    "files": [
  "index.html",
  "main.js",
  "preload.js",
  "supabase.js",
  "whitelist.json",
  "oauth_credentials.json",
  ".env",
  "package.json",
  "node_modules/**/*"
],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "icon.icns",
      "target": {
        "target": "dmg",
        "arch": ["arm64"]
      }
    },
    "dmg": {
      "title": "Gesturo"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/lib-storage": "^3.1023.0",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.0"
  }
}