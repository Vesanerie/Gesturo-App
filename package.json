{
  "name": "gesturo",
  "version": "0.1.7",
  "description": "Entraînement au dessin de poses",
  "author": "Gesturo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "mobile:sync": "node scripts/sync-web.js && cap sync",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:android": "npm run mobile:sync && cap open android"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/lib-storage": "^3.1023.0",
    "@capacitor/cli": "^8.3.0",
    "@electron/notarize": "^3.1.1",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.gesturo.app",
    "productName": "Gesturo",
    "publish": {
      "provider": "github",
      "owner": "Vesanerie",
      "repo": "gesturo-releases",
      "private": true
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "moodboard-preload.js",
      "moodboard/**/*",
      "styles/**/*",
      "src/**/*",
      "supabase.js",
      "config.js",
      "whitelist.json",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "identity": "E88066B362342ED5B335648D3C717FD2634EE02A",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false,
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      }
    },
    "dmg": {
      "title": "Gesturo"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.0",
    "electron-updater": "^6.8.3"
  }
}
