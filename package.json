{
  "name": "gesturo",
  "version": "0.3.0",
  "description": "Entraînement au dessin de poses",
  "author": "Gesturo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "check": "node scripts/health-check.js",
    "smoke": "node scripts/smoke-test.js",
    "mobile:sync": "node scripts/sync-web.js && cap sync",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:android": "npm run mobile:sync && cap open android",
    "deploy:functions": "npx supabase functions deploy list-r2-photos --no-verify-jwt && npx supabase functions deploy list-r2-animations --no-verify-jwt && npx supabase functions deploy list-instagram-posts --no-verify-jwt && npx supabase functions deploy user-data --no-verify-jwt && npx supabase functions deploy admin-r2 --no-verify-jwt && npx supabase functions deploy stripe-webhook --no-verify-jwt && npx supabase functions deploy daily-challenge --no-verify-jwt"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "dotenv": "^17.4.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "com.gesturo.app",
    "productName": "Gesturo",
    "publish": {
      "provider": "github",
      "owner": "Vesanerie",
      "repo": "gesturo-releases",
      "private": true
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "moodboard-preload.js",
      "moodboard/**/*",
      "styles/**/*",
      "src/**/*",
      "assets/**/*",
      "supabase.js",
      "config.js",
      "blocked-usernames.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "identity": "E88066B362342ED5B335648D3C717FD2634EE02A",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false,
      "target": {
        "target": "dmg",
        "arch": [
          "universal"
        ]
      }
    },
    "win": {
      "icon": "icon.ico",
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "dmg": {
      "title": "Gesturo"
    }
  },
  "dependencies": {
    "@capacitor-mlkit/document-scanner": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.101.1",
    "electron-updater": "^6.8.3",
    "playwright-core": "^1.59.1"
  }
}
